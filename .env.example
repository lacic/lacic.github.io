# Azure OpenAI Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT commit the .env file to git

# Azure OpenAI API Base URL
# Format: https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_BASE=https://your-resource.openai.azure.com/

# Azure OpenAI API Key
# Found in Azure Portal > Your OpenAI Resource > Keys and Endpoint
AZURE_OPENAI_API_KEY=your-api-key-here

# Azure OpenAI API Version
# Use the API version supported by your deployment
# Common versions: 2024-02-15-preview, 2023-12-01-preview
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI Deployment Name
# The name you gave your model deployment in Azure
# Example: gpt-4, gpt-35-turbo, etc.
AZURE_OPENAI_DEPLOYMENT=gpt-4
